<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.doctor</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/fish</string>
        <string>-l</string>
        <string>-c</string>
        <string>doctor-notify</string>
    </array>
    <key>StandardOutPath</key>
    <string>/tmp/local.doctor.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/local.doctor.err</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
</dict>
</plist>
