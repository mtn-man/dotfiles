{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.11.2",
  "schemes" : [
    {
      "buttons" : {
        "gesture" : {
          "actions" : {
            "down" : "appExpose",
            "left" : "missionControl.spaceRight",
            "right" : "missionControl.spaceLeft",
            "up" : "missionControl"
          },
          "enabled" : true,
          "threshold" : 50,
          "trigger" : {
            "button" : 2
          }
        },
        "universalBackForward" : true
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xc53f",
          "productName" : "USB Receiver",
          "vendorID" : "0x46d"
        }
      },
      "pointer" : {
        "acceleration" : 1.3,
        "disableAcceleration" : true
      },
      "scrolling" : {
        "reverse" : {
          "vertical" : true
        }
      }
    },
    {
      "buttons" : {
        "universalBackForward" : true
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xfaa0",
          "productName" : "ProtoArc EM11 NL",
          "vendorID" : "0x25a7"
        }
      },
      "pointer" : {
        "disableAcceleration" : true
      },
      "scrolling" : {
        "reverse" : {
          "vertical" : true
        }
      }
    },
    {
      "buttons" : {
        "universalBackForward" : true
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xfa61",
          "productName" : "2.4G Receiver",
          "vendorID" : "0x25a7"
        }
      },
      "pointer" : {
        "disableAcceleration" : true
      },
      "scrolling" : {
        "reverse" : {
          "vertical" : true
        }
      }
    }
  ]
}