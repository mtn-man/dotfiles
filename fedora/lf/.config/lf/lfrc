set sortby time
set reverse true
map o &xdg-open "$fx"
map <enter> &xdg-open "$fx"
map . set hidden!
map d $trash "$fx"
map <backspace2> $trash "$fx"
set shell /usr/bin/fish
map S shell
map R reload
map e $micro "$fx"
map c copy
map v paste
map <esc> quit
map D delete
map H cd ~
map x cut
map C clear
set previewer ~/.config/lf/pv.sh
set cleaner ~/.config/lf/clean.sh

# --- zoxide integration (fish-compatible) ---

# Teach zoxide about directories visited in lf
cmd cd ${{
    command cd -- $argv
    if type -q zoxide
        zoxide add -- $PWD >/dev/null 2>&1
    end
}}

cmd z ${{
    if not type -q zoxide
        exit 0
    end

    set -l dir

    if test (count $argv) -gt 0
        set dir (zoxide query -- $argv)
    else
        set dir (zoxide query -i)
    end

    if test -n "$dir"
        # Quote for lf: wrap in single quotes and escape any single quotes inside
        set -l q (string replace -a "'" "'\\''" -- "$dir")
        lf -remote "send $id cd '$q'"
    end
}}
map z z
